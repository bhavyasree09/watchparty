{
  "name": "youware-react-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    // use node to invoke vite binary (avoids permission denied on Vercel)
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    // ensure the vite bin is executable after install
    "postinstall": "chmod +x node_modules/.bin/vite"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.18",
    "@supabase/supabase-js": "^2.97.0",
    "cannon-es": "^0.20.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.18.2",
    "gsap": "^3.13.0",
    "i18next": "^23.10.1",
    "i18next-browser-languagedetector": "^7.2.0",
    "lucide-react": "^0.533.0",
    "matter-js": "^0.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.0",
    "react-player": "^3.4.0",
    "react-router-dom": "^6.30.3",
    "react-use": "^17.6.0",
    "simple-peer": "^9.11.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.179.1",
    "zod": "^3.25.67",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/matter-js": "^0.20.0",
    "@types/node": "^24.0.14",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/simple-peer": "^9.11.9",
    "@vitejs/plugin-react": "^4.5.2",
    "@youware/vite-plugin-react": "^1.0.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^7.0.0"
  }
}
